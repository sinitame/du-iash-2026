{
  "dataset": "data/dataset_test.csv",
  "output_dir": "outputs",
  "chatbot_prompt_file": "prompts/chatbot_baseline.txt",
  "judge_prompt_file": "prompts/judge_v1.txt",
  "temperature": 0,
  "max_tokens": 500,
  "baseline_system": "openai_gpt_5_mini",
  "systems": [
    {
      "name": "test_technique",
      "type": "reference"
    },
    {
      "name": "openai_gpt_5_mini",
      "model": "gpt-5-mini",
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "output_tokens_parameter": "max_completion_tokens",
      "use_temperature": false,
      "request_options": {
        "reasoning_effort": "minimal"
      }
    },
    {
      "name": "openai_gpt_4_1_mini",
      "model": "gpt-4.1-mini",
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "output_tokens_parameter": "max_tokens"
    },
    {
      "name": "openai_gpt_4_turbo",
