{
  "dataset": "data/dataset_test.csv",
  "output_dir": "outputs",
  "judge_prompt_file": "prompts/judge_v2.txt",
  "temperature": 0,
  "max_tokens": 500,
  "provider_transport": {
    "openai": {
      "max_concurrency": 4,
      "max_retries": 5,
      "retry_base_seconds": 2,
      "retry_max_seconds": 20
    },
    "mistral": {
      "max_concurrency": 4,
      "max_retries": 5,
      "retry_base_seconds": 2,
      "retry_max_seconds": 20
    },
    "anthropic": {
      "max_concurrency": 4,
      "max_retries": 5,
      "retry_base_seconds": 2,
      "retry_max_seconds": 20,
      "prompt_cache": {
        "enabled": true,
        "ttl": "5m"
      }
    }
  },
  "rag": {
    "vectorstore_path": "../rag/vectorstore_mici",
    "embedding_model": "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2",
    "device": "cpu",
    "normalize_embeddings": true,
    "k": 5,
    "fetch_k": 20,
    "max_context_chars": 6000,
    "max_chunk_chars": 1200,
    "filter_by_language": true
  },
  "rag_selective": {
    "vectorstore_path": "../rag/vectorstore_mici",
    "embedding_model": "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2",
    "device": "cpu",
    "normalize_embeddings": true,
    "k": 3,
    "fetch_k": 12,
    "max_distance": 1.1,
    "max_context_chars": 3600,
    "max_chunk_chars": 1200,
    "filter_by_language": true,
    "citation_policy": "Utilise uniquement les passages directement pertinents pour la question. Ignore les passages périphériques, insuffisants ou contradictoires. Le contexte est une source d'appui: tu n'es pas obligé d'utiliser chaque passage.",
    "no_answer_policy": "Si aucun passage n'est suffisamment pertinent, réponds prudemment à partir de tes connaissances générales sans inventer d'information et indique les limites utiles."
  },
  "rag_generate_baseline": false,
  "baseline_system": "openai_gpt_5_mini",
  "systems": [
    {
      "name": "test_technique",
      "type": "reference"
    },
    {
      "name": "openai_gpt_5_mini",
      "model": "gpt-5-mini",
      "provider": "openai",
      "model_group": "advanced",
      "prompt_variant": "baseline",
      "prompt_file": "prompts/chatbot_baseline.txt",
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "output_tokens_parameter": "max_completion_tokens",
      "max_tokens": 1000,
      "use_temperature": false,
      "request_options": {
        "reasoning_effort": "minimal"
      }
    },
    {
      "name": "openai_gpt_5_mini_step_by_step",
      "model": "gpt-5-mini",
      "provider": "openai",
      "model_group": "advanced",
      "prompt_variant": "step_by_step",
      "prompt_file": "prompts/chatbot_step_by_step.txt",
      "base_url": "https://api.openai.com/v1",
      "api_key_env": "OPENAI_API_KEY",
      "output_tokens_parameter": "max_completion_tokens",
      "max_tokens": 1000,
      "use_temperature": false,
      "request_options": {
        "reasoning_effort": "minimal"
      }
    },
    {
      "name": "mistral_medium_2508",
      "model": "mistral-medium-2508",
      "provider": "mistral",
      "model_group": "advanced",
      "prompt_variant": "baseline",
      "prompt_file": "prompts/chatbot_baseline.txt",
      "base_url": "https://api.mistral.ai/v1",
      "api_key_env": "MISTRAL_API_KEY",
      "output_tokens_parameter": "max_tokens"
    },
    {
      "name": "mistral_medium_2508_step_by_step",
      "model": "mistral-medium-2508",
      "provider": "mistral",
      "model_group": "advanced",
